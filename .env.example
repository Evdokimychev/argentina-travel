# ── Public site (required in production) ──
# Canonical origin for sitemap, robots, JSON-LD, Open Graph
NEXT_PUBLIC_SITE_URL=https://www.goargentina.ru
# Optional: display domain in PDF/emails (defaults to hostname from SITE_URL)
NEXT_PUBLIC_SITE_DOMAIN=www.goargentina.ru

# Supabase (public — safe in browser with RLS)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Supabase Auth + bookings + shop (set to false for localStorage-only mode)
NEXT_PUBLIC_SUPABASE_AUTH=true

# Published tours catalog mirror in Postgres (requires NEXT_PUBLIC_SUPABASE_AUTH)
NEXT_PUBLIC_SUPABASE_TOURS=true
# Tours source mode:
# - supabase: strict single source of truth (no TS-seed fallback when remote enabled)
# - hybrid: Supabase first, then local TS seeds as temporary fallback
NEXT_PUBLIC_TOURS_SOURCE=supabase

# Server-only
SUPABASE_SERVICE_ROLE_KEY=
DATABASE_URL=
# CMS media: skip manifest.json writes on upload (auto on Vercel). Run npm run sync-cms-media-manifest locally/CI.
# CMS_MEDIA_SKIP_MANIFEST_SYNC=1

# Public API v1 (E70) — comma-separated partner origins for browser CORS
# Example: https://partner.example.com,https://widgets.example.org
PUBLIC_API_CORS_ORIGINS=
# Mercado Pago Checkout Pro (Argentina)
# Required for creating checkout preferences from /api/bookings/[id]/payment/preference
MERCADOPAGO_ACCESS_TOKEN=
# Required for verifying webhook HMAC signature in /api/webhooks/payments/mercadopago
MERCADOPAGO_WEBHOOK_SECRET=
# Set MERCADOPAGO_REFUNDS_ENABLED=true to allow admin-approved refunds via MP API
# (requires MERCADOPAGO_ACCESS_TOKEN with refund permissions)
MERCADOPAGO_REFUNDS_ENABLED=
# Public key for future Mercado Pago Brick / 3DS checkout (client-side tokenization)
NEXT_PUBLIC_MERCADOPAGO_PUBLIC_KEY=
# Server-only alias (optional if NEXT_PUBLIC_* is set)
MERCADOPAGO_PUBLIC_KEY=
# Future: organizer payout settlement via Mercado Pago Marketplace / split payments
# MERCADOPAGO_PAYOUT_ACCESS_TOKEN=

# Stripe Checkout (international card payments)
# Required for creating checkout sessions from /api/bookings/[id]/payment/stripe/session
STRIPE_SECRET_KEY=
# Required for verifying webhook signatures in /api/webhooks/payments/stripe
STRIPE_WEBHOOK_SECRET=
# Publishable key for client-side provider selection UI
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
# Optional: explicit enable flag (defaults to true when STRIPE_SECRET_KEY is set server-side)
STRIPE_ENABLED=
NEXT_PUBLIC_STRIPE_ENABLED=

# Places knowledge base (Prisma Postgres — optional; seed JSON works without DB)
PLACES_USE_DB=false
# GEONAMES_USERNAME=

# Admin access requires Supabase session + profiles.roles admin (LEADS_ADMIN_TOKEN removed in E7)

# Optional notifications
RESEND_API_KEY=
LEADS_NOTIFY_EMAIL=
LEADS_NOTIFY_FROM=noreply@goargentina.ru
# Optional recipients for E86 freshness report cron (comma-separated).
# Falls back to LEADS_NOTIFY_EMAIL when empty.
CONTENT_FRESHNESS_NOTIFY_EMAILS=
# HMAC secret for one-click email unsubscribe tokens (defaults to SUPABASE_SERVICE_ROLE_KEY)
NOTIFICATION_UNSUBSCRIBE_SECRET=
# Web push (E83, VAPID). If keys are missing, push delivery is silently disabled.
NEXT_PUBLIC_WEB_PUSH_VAPID_PUBLIC_KEY=
WEB_PUSH_VAPID_PRIVATE_KEY=
# mailto:ops@goargentina.ru or https://example.com/contact
WEB_PUSH_VAPID_SUBJECT=mailto:ops@goargentina.ru

# Demo seed in localStorage (MUST be false in production)
NEXT_PUBLIC_ENABLE_DEMO_SEED=false

# Travelpayouts whitelabel embeds (/flights, /insurance)
NEXT_PUBLIC_TRAVELPAYOUTS_WL_ID=
TRAVELPAYOUTS_API_KEY=
TRAVELPAYOUTS_MARKER=434047
TRAVELPAYOUTS_TRS=427300
# Optional: set to false to keep long partner URLs
TRAVELPAYOUTS_SHORTEN_LINKS=true
# Insurance WL embed uses TRAVELPAYOUTS_TRS/MARKER (campaign_id=24, promo_id=1498) — see /insurance

# Intui transfers API (server-only — native search + affiliate deep links)
# Request access: https://support.travelpayouts.com/hc/ru/articles/360016804119
# Write to Travelpayouts support to receive INTUI_API_KEY (typically for 20k+ MAU projects).
# API base: https://api.intui.travel/ver1_0/{MethodName}/ — auth via JSON POST field `apikey`.
INTUI_API_KEY=
# Optional: Intui partner ID (defaults to TRAVELPAYOUTS_MARKER for affiliate deep links)
INTUI_PARTNER_ID=
INTUI_API_BASE_URL=https://api.intui.travel/ver1_0
INTUI_DEFAULT_LANG=ru
INTUI_DEFAULT_CURRENCY=USD

# Airalo eSIM feed (Travelpayouts — native catalog + affiliate links)
# Docs: https://support.travelpayouts.com/hc/ru/articles/17131439719826
# Download feed in Travelpayouts dashboard (Airalo program) and set URL or local path.
AIRALO_FEED_URL=
AIRALO_FEED_PATH=data/feeds/airalo-feed.xml
AIRALO_FEED_CACHE_MINUTES=60
# Pre-built partner link from Travelpayouts Tools (short link to Airalo homepage)
AIRALO_AFFILIATE_HOME_URL=

TRIPSTER_PARTNER=travelpayoutsapi
TRIPSTER_SECRET=
TRIPSTER_API_BASE=https://experience.tripster.ru/api
# Sync scope — default: all Argentina cities
TRIPSTER_SYNC_COUNTRY=argentina
# Skip affiliate generation during sync (use tripster:affiliate-links separately)
# TRIPSTER_SKIP_AFFILIATE_LINKS=true
# TRIPSTER_SYNC_REVIEWS=true
# TRIPSTER_AFFILIATE_DELAY_MS=700
# Live schedule fetch for catalog listings (default off — use schedule_snapshot from sync)
# TRIPSTER_ENRICH_LISTING_SCHEDULE=true

# Sputnik8 excursions API (Travelpayouts partner dashboard → Access to Sputnik8 API)
# Docs: https://www.sputnik8.com/doc/api
SPUTNIK8_API_KEY=
SPUTNIK8_USERNAME=
SPUTNIK8_API_BASE=https://api.sputnik8.com/v1
SPUTNIK8_SYNC_COUNTRY=argentina
SPUTNIK8_DEFAULT_LANG=ru
SPUTNIK8_DEFAULT_CURRENCY=USD
# SPUTNIK8_SKIP_AFFILIATE_LINKS=true
# SPUTNIK8_SYNC_REVIEWS=true
# SPUTNIK8_COUNTRY_ID=

# YouTravel.me partner tours API — v2 partner endpoints (BasicAuth)
# Docs: https://ytme.atlassian.net/wiki/external/NTA0ZDQ5OTRhODFjNDcwYjkxMzBjMWVlNWY0YmNlMjE
YOUTRAVEL_API_BASE=https://youtravel.me/api
YOUTRAVEL_API_EMAIL=
YOUTRAVEL_API_PASSWORD=
YOUTRAVEL_AUTH_MODE=basic_password
YOUTRAVEL_PARTNER_PID=1173
YOUTRAVEL_API_LANG=ru
YOUTRAVEL_SERP_CURRENCY=usd
YOUTRAVEL_DETAIL_CURRENCY=USD
# YOUTRAVEL_SERP_MAX_PAGES=60
YOUTRAVEL_SYNC_COUNTRY=argentina

# YouTravel.me Affise affiliate stats API (separate from tour catalog above)
# Docs: https://api-travelme.affise.com/docs3.1/ — stats/conversions/clicks only
# Auth: API-Key header (or ?API-Key= query param). Key from Affise partner profile.
# Do NOT point YOUTRAVEL_API_BASE here — Affise has no /v1/tours endpoint.
# Daily snapshots: /api/cron/youtravel-affise-snapshot (also via affiliate-sync cron)
YOUTRAVEL_AFFISE_API_BASE=https://api-travelme.affise.com
YOUTRAVEL_AFFISE_API_KEY=
# Playwright E2E: slug YouTravel-тура (…-yt{id}) для tests/e2e/youtravel-booking.spec.ts
# YOUTRAVEL_E2E_TOUR_SLUG=patagoniya-yt52537
# Webhook secret for POST /api/webhooks/youtravel/booking (header x-youtravel-webhook-secret or ?secret=)
# YOUTRAVEL_WEBHOOK_SECRET=

# Cron (E71 — production on Vercel via vercel.json)
# Vercel sends Authorization: Bearer <CRON_SECRET> or x-vercel-cron header
# Manual trigger: POST /api/cron/... with Authorization: Bearer <CRON_SECRET>
CRON_SECRET=

# Meilisearch (optional — site search v3 layer over Postgres FTS, E45)
# Without these vars search falls back to Postgres FTS (E38) or static index.
MEILISEARCH_HOST=
MEILISEARCH_API_KEY=

# Guide assistant (E68) — optional AI over guide/blog/immigration content
# Without keys POST /api/assistant/ask falls back to search snippets (no 503).
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-haiku-20241022
# openai | anthropic — optional preference when both keys are set
GUIDE_ASSISTANT_PROVIDER=

# ── Monitoring (optional, recommended in production) ──
# Sentry: create project at sentry.io → Settings → Client Keys (DSN)
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
# Optional: for source map upload in CI
# SENTRY_AUTH_TOKEN=
# SENTRY_ORG=
# SENTRY_PROJECT=
# Optional: alerts for cron failures (incoming Slack webhook URL)
SLACK_OPS_WEBHOOK=

# ── Web analytics (Google Tag Manager + Consent Mode v2) ──
# Create container at tagmanager.google.com → copy GTM-XXXXXXX
NEXT_PUBLIC_GTM_ID=
# Reference IDs for GTM tag configuration (tags fire inside GTM, not in app code)
NEXT_PUBLIC_GA4_MEASUREMENT_ID=
NEXT_PUBLIC_YM_COUNTER_ID=
NEXT_PUBLIC_CLARITY_PROJECT_ID=
# Search engine / SEO tool verification (optional — also editable in Admin → Settings → SEO)
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=
NEXT_PUBLIC_BING_SITE_VERIFICATION=
NEXT_PUBLIC_AHREFS_SITE_VERIFICATION=
NEXT_PUBLIC_YANDEX_SITE_VERIFICATION=qjx41i40i9avxij2

# Build metadata (CI sets GIT_SHA automatically; optional APP_VERSION override)
# GitHub Actions: see .github/workflows/ci.yml
GIT_SHA=
# APP_VERSION=0.1.0

# Deployment environment label (E72) — staging | production
# Used by /api/health and admin readiness panel. Set explicitly on each host.
# Vercel: also inferred from VERCEL_ENV=production when DEPLOY_ENV is unset.
DEPLOY_ENV=production

# ── Staging (separate Supabase project — see docs/DEPLOY.md) ──
# Use on preview/staging host; map to NEXT_PUBLIC_* / DATABASE_URL in deploy settings
STAGING_NEXT_PUBLIC_SITE_URL=
STAGING_NEXT_PUBLIC_SUPABASE_URL=
STAGING_NEXT_PUBLIC_SUPABASE_ANON_KEY=
STAGING_SUPABASE_SERVICE_ROLE_KEY=
STAGING_DATABASE_URL=

# Stock media (scripts/fetch-stock-media.mjs — download hero/gallery JPEGs to public/media/)
UNSPLASH_ACCESS_KEY=
PEXELS_API_KEY=
