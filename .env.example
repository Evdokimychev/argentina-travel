# Supabase — https://supabase.com/dashboard/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
# Publishable (anon) key — safe for browser with RLS enabled
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-publishable-or-anon-key

# Optional: server-only admin operations (never expose to client)
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Admin leads inbox (/admin/leads) — bearer token for GET /api/admin/leads
# LEADS_ADMIN_TOKEN=generate-a-long-random-string

# Optional: email alerts for new leads (Resend)
# RESEND_API_KEY=re_...
# LEADS_NOTIFY_EMAIL=you@example.com
# LEADS_NOTIFY_FROM=onboarding@resend.dev

# Demo localStorage seeds — off in production by default; set false locally to disable
# NEXT_PUBLIC_ENABLE_DEMO_SEED=false

# For Supabase CLI / local migrations only (never commit real credentials)
# DATABASE_URL=postgresql://postgres:password@db.your-project.supabase.co:5432/postgres
