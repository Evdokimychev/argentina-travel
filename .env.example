# Supabase (public — safe in browser with RLS)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Supabase Auth + bookings + shop (set to false for localStorage-only mode)
NEXT_PUBLIC_SUPABASE_AUTH=true

# Published tours catalog mirror in Postgres (requires NEXT_PUBLIC_SUPABASE_AUTH)
NEXT_PUBLIC_SUPABASE_TOURS=true

# Server-only
SUPABASE_SERVICE_ROLE_KEY=
DATABASE_URL=

# Admin inbox + seed scripts
LEADS_ADMIN_TOKEN=

# Optional notifications
RESEND_API_KEY=
LEADS_NOTIFY_EMAIL=

# Demo seed in localStorage (disable in production)
NEXT_PUBLIC_ENABLE_DEMO_SEED=true

# Travelpayouts (server-only — affiliate link generation)
TRAVELPAYOUTS_API_KEY=
TRAVELPAYOUTS_MARKER=434047
TRAVELPAYOUTS_TRS=427300
# Optional: set to false to keep long partner URLs
TRAVELPAYOUTS_SHORTEN_LINKS=true

# Tripster partner API (server-only — catalog sync, not exposed to browser)
TRIPSTER_PARTNER=travelpayoutsapi
TRIPSTER_SECRET=
TRIPSTER_API_BASE=https://experience.tripster.ru/api
# Sync scope — default: all Argentina cities
TRIPSTER_SYNC_COUNTRY=argentina
# Skip affiliate generation during sync (use tripster:affiliate-links separately)
# TRIPSTER_SKIP_AFFILIATE_LINKS=true
# TRIPSTER_SYNC_REVIEWS=true
# TRIPSTER_AFFILIATE_DELAY_MS=700

# Cron (production only on Vercel): daily sync via vercel.json
# Manual trigger: GET /api/cron/tripster-sync with Authorization: Bearer <CRON_SECRET>
CRON_SECRET=
